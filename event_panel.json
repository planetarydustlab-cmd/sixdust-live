0 15px 3px var(--_g),0 0 26px 7px var(--_g2,transparent)}}\n/* 行星球體：受光面 highlight + 暗緣 + 光暈 */\n.sd-planet{--_d:32px;--_c:var(--sd-neutral);--_g:rgba(154,165,184,.4);--_g2:rgba(154,165,184,.14);\n  display:inline-block;flex:0 0 auto;width:var(--_d);height:var(--_d);border-radius:50%;\n  background:radial-gradient(circle at 34% 30%,rgba(255,255,255,.6),rgba(255,255,255,0) 42%),\n             radial-gradient(circle at 50% 56%,var(--_c),#0a0d12 84%);\n  box-shadow:0 0 12px 1px var(--_g),inset 0 0 9px -3px #000a;\n  animation:sd-bob var(--sd-bob-dur) ease-in-out infinite,sd-halo var(--sd-halo-dur) ease-in-out infinite}\n.sd-planet.tw-strong{--_c:var(--sd-tw-strong);--_g:rgba(74,222,128,.5);--_g2:rgba(74,222,128,.15)}\n.sd-planet.tw-weak{--_c:var(--sd-tw-weak);--_g:rgba(248,113,113,.5);--_g2:rgba(248,113,113,.15)}\n.sd-planet.us-strong{--_c:var(--sd-us-strong);--_g:rgba(74,222,128,.5);--_g2:rgba(74,222,128,.15)}\n.sd-planet.us-weak{--_c:var(--sd-us-weak);--_g:rgba(248,113,113,.5);--_g2:rgba(248,113,113,.15)}\n.sd-planet.ember{--_c:var(--sd-ember);--_g:rgba(255,138,61,.55);--_g2:rgba(255,138,61,.18)}\n.sd-planet.neutral{--_c:var(--sd-neutral);--_g:rgba(154,165,184,.38)}\n/* 浮力標網格：六（三/二）格行星量表，逐格浮力上升 */\n.sd-buoy-grid{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:1px;\n  background:var(--hair,var(--border,#232a36));border:1px solid var(--hair,var(--border,#232a36));\n  border-radius:3px;overflow:hidden}\n.sd-gauge{position:relative;display:flex;flex-direction:column;align-items:center;gap:9px;\n  padding:17px 12px 15px;background:var(--ink,var(--bg-card,#0e1015));\n  animation:sd-rise var(--sd-rise-dur) var(--sd-rise-ease) both;animation-delay:calc(var(--i,0) * var(--sd-rise-step))}\n.sd-gauge .sd-planet{--_d:30px}\n.sd-g-v{font-family:var(--num,ui-monospace,Menlo,monospace);font-size:18px;font-weight:600;\n  color:#eef2f7;line-height:1;font-variant-numeric:tabular-nums}\n.sd-g-v small{font-size:11px;color:var(--text-3,#6b7385);font-weight:400;margin-left:1px}\n.sd-g-k{font-size:10px;letter-spacing:.08em;color:var(--text-3,#6b7385);display:flex;align-items:center;gap:5px;\n  white-space:nowrap;text-align:center}\n.sd-mkt{font-family:var(--num,ui-monospace,monospace);font-size:8.5px;letter-spacing:.06em;padding:1px 4px;border-radius:2px;font-weight:700}\n.sd-mkt.tw{color:var(--sd-tw-strong);background:rgba(74,222,128,.1)}\n.sd-mkt.us{color:var(--sd-us-strong);background:rgba(74,222,128,.1)}\n/* 浮力晶片（BUOYANCY 面板：行星 + 名稱 + 值）*/\n.sd-chip{display:inline-flex;align-items:center;gap:6px;font-size:11px;color:#cdd6e4;\n  background:#10131a;border:1px solid var(--border,#232a36);border-radius:6px;padding:3px 8px 3px 6px}\n.sd-chip .sd-planet{--_d:13px}\n.sd-chip b{font-weight:600;font-variant-numeric:tabular-nums}\n/* 軌道/地平線（HORIZON 前方事件：NOW → 前方航點行星，可橫捲）*/\n.sd-orbit{position:relative;display:flex;align-items:flex-start;gap:0;overflow-x:auto;scrollbar-width:none;\n  padding:16px 2px 4px;margin-top:2px}\n.sd-orbit::-webkit-scrollbar{display:none}\n.sd-orbit::before{content:\"\";position:absolute;left:6px;right:6px;top:23px;height:1px;\n  background:linear-gradient(90deg,var(--sd-ember),rgba(255,138,61,.15) 62%,transparent)}\n.sd-node{flex:0 0 auto;position:relative;display:flex;flex-direction:column;align-items:center;gap:4px;\n  padding:0 11px;min-width:58px;text-decoration:none;\n  animation:sd-rise var(--sd-rise-dur) var(--sd-rise-ease) both;animation-delay:calc(var(--i,0) * var(--sd-rise-step))}\n.sd-node .sd-planet{--_d:13px;margin-bottom:1px}\n.sd-node.sd-now .sd-planet{--_d:9px}\n.sd-node b{font-family:var(--mono,var(--num,ui-monospace,monospace));font-size:11px;color:#cdd6e4;font-variant-numeric:tabular-nums}\n.sd-node .sd-t{font-size:9.5px;line-height:1.35;color:#9aa5b8;max-width:70px;text-align:center}\n.sd-node i{font-style:normal;font-family:var(--mono,var(--num,monospace));font-size:9px;color:#6b7385;letter-spacing:.04em}\n.sd-node.sd-now b{color:var(--sd-ember);letter-spacing:.14em}\n.sd-node.hot b,.sd-node.hot i{color:var(--sd-ember)}\n.sd-node.hot .sd-t{color:#e8edf2}\n.sd-node:hover .sd-t{color:#e8edf2}\n@media(max-width:760px){.sd-buoy-grid{grid-template-columns:repeat(3,minmax(0,1fr))}}\n@media(max-width:400px){.sd-buoy-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}\n@media(prefers-reduced-motion:reduce){.sd-planet,.sd-gauge,.sd-node{animation:none!important}}\n@media print{.sd-planet,.sd-gauge,.sd-node{animation:none!important}}\n</style>\n<div class=\"con-posture\"><div class=\"con-tagcell\">TODAY<span>今日盤勢</span></div><div class=\"con-body\"><div style=\"display:flex;align-items:center;gap:7px 12px;flex-wrap:wrap;margin-bottom:9px\"><span style=\"font-size:11px;color:#6b7385\">2026-07-24 週五 · 盤後 · 資料 14:10</span><span style=\"font-size:11px;padding:2px 9px;border-radius:100px;border:1px solid #3a4150;color:#cdd6e4\">risk-off 偏空</span><span style=\"font-size:11px;padding:2px 9px;border-radius:100px;background:#f871711f;border:1px solid #f8717166;color:#f87171;font-weight:700\">氣壓 -2/6 偏逆風</span><span style=\"font-size:11px;padding:2px 9px;border-radius:100px;background:rgba(248,113,113,.12);border:1px solid rgba(248,113,113,.4);color:#f87171;font-weight:700\">● 事件風險 啟動中</span></div><div style=\"font-size:15px;line-height:1.62;color:#eef2f7;font-weight:500\">昨天勉強撐平的台股今天全面潰堤——KOSPI 暴跌 6%、SK 海力士 -7.3% 點燃亞洲半導體連鎖賣壓，台股收跌 1,195 點（-2.67%）至 43,654，台積電跌 55 元收 2,350；Brent 站穩 100.3 美元</div><div style=\"margin-top:10px;border-top:1px solid #232a36;padding-top:8px\"><div style=\"font-family:ui-monospace,monospace;font-size:9.5px;letter-spacing:.16em;color:#6b7385;margin-bottom:5px\">HISTORY · 過去盤勢（近 20 日判讀 · 可捲動）</div><div style=\"max-height:118px;overflow-y:auto;scrollbar-width:thin;padding-right:6px\"><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/23 週四</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">荷莫茲海峽「完全封鎖」將 Brent 推上 97.59（+3.74%），記憶體族群受財報利空衝擊盤中重挫逾 4.5%，台股從昨日的 +1.63% 驟縮至 +0.06% 收 44,850——昨天「無視油價、只看財報」的劇本被改寫了一半</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/22 週三</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">SOX 飆漲 5.21% 帶動台股反彈 1.63% 至 44,955，荷莫茲油輪起火推升 Brent 重返 92.22；市場押注 07/24 科技財報週、選擇無視油價，但氣壓場仍掛三力逆風，轉折看財報兌現。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/21 週二</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">荷莫茲海峽美軍空襲進入第十夜，但 Brent 反從上週五 90.85 回落至 89.0、VIX 降至 18.65，氣壓場從四力亮紅收斂為三力逆風；台股續跌 0.52% 至 42,450，07/24 科技財報週前市場在「恐慌退潮」與「利空未結」間拉鋸。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/20 週一</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">台股上週五暴跌 2,954 點（-6.47%）至 42,671，Brent 同步飆至 90.85 美元，本庫氣壓場六力中四力亮紅；07/24 起美國科技巨頭 Q2 財報能否撐住 AI 敘事，是短線止跌與否的分水嶺。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/19 週日</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">本輪公開新聞未出現明確 CRITICAL/HIGH 主軸；事件風險暫無升級,但仍需等下一輪新聞與市場 tape 驗證。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/18 週六</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">本輪公開新聞未出現明確 CRITICAL/HIGH 主軸；事件風險暫無升級,但仍需等下一輪新聞與市場 tape 驗證。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/17 週五</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">台股今天跌掉 2,953 點（−6.47%）、台積電收 2,290（−7.29%），但美股與黃金幾乎沒動——這是台股單邊的恐慌宣洩，不是全球風險事件；止跌的第一個路標在 07/24 起的 hyperscaler 財報 capex。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/16 週四</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">SOX 12399（−2.08%）因記憶體股暴跌而與 S&amp;P 7572（+0.38%）形成單日罕見背離，今日台積電法說將驗證這究竟是記憶體獨弱、還是半導體全面修正的序曲。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/15 週三</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">SOX 12661（+2.54%）與 VIX 16.5（−3.85%）隔夜同步修復，CPI 降溫加上川普撤回荷莫茲 20% 關稅構成雙重釋壓，但 Brent 85.21 因伊朗制裁重啟仍居高——7/16 台積電法說將驗證半導體反彈是否僅為技術性回補。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/14 週二</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">SOX 12347（−4.78%）與 VIX 17.16（+14.17%）確認美股已開始定價荷莫茲海峽風險，SK 海力士財測下修加劇記憶體賣壓，今日美國 6 月 CPI 將驗證油價跳升是否已滲入核心通膨讀數。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/13 週一</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">Brent 78.47（+3.24%）因荷莫茲海峽衝突單日跳升，但 VIX 15.03 反降 5.11% 顯示美股尚未定價地緣溢價，明日 CPI 將決定油價衝擊是否傳導為通膨敘事升級。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/12 週日</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">S&amp;P 500 7575 距年高僅 0.6% 且 VIX 15.03 壓至近年低，但台積電 2415（-2.03%）與費半 +0.06% 形成明確分歧，7/16 法說前半導體族群須獨立驗證動能是否斷裂。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/11 週六</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">S&amp;P 500 7575（+0.42%）距年高僅 0.6%、VIX 15.03（-5.11%）逼近年低，荷莫茲緩解推油價回落；費半 12967 動能驟降至 +0.06%，7/14 CPI 與 7/16 台積法說是突破或回吐的雙驗證。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/10 週五</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">SOX 12960（+3.06%）連兩日累彈逾 5%、VIX 15.84（-6.27%）急落，AI 熱度壓過荷莫茲戰火；但台積電 2415（-2.03%）逆跌，今日 6 月營收是 AI 多頭敘事能否穿透台股的即時驗證。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/09 週四</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">SOX 12575（+2.23%）逆勢回補昨日近半跌幅，但 Brent 78.87 連兩日走高、VIX 16.9（+4.77%）同步攀升，7/10 台積電營收若低於預期將戳破半導體脫鉤油價壓力的敘事。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/08 週三</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">SOX 12300（-4.65%）一夜吞沒週一全數反彈，Brent 76.22（+2.78%）因荷莫茲油輪遇襲急彈；7/10 台積電營收是晶片族群信心能否止穩的最近驗證窗口。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/07 週二</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">SOX 12900（+2.17%）週一直接收復上週五踩踏缺口，S&amp;P 7537 輕鬆站穩 7400 分水嶺；荷莫茲通航正常化令 Brent 72.23 僅微升 +0.33%，本週焦點前移至 7/10 台積電營收與 7/14 CPI 雙驗證。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/06 週一</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">非農僅 57K 急凍就業市場，金價 4212.1（+2.09%）搶跑降息交易，但 SOX 12626（−5.44%）踩踏傷口在週一美股開盤前仍未驗收；S&amp;P 能否守 7400、SOX 止穩 12500 是本週分水嶺。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/05 週日</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">霍姆茲重開疊加 OPEC 六月增產，Brent 72.13（+0.46%）微漲已在定價油市過剩；SOX 12626（−5.44%）崩跌源頭浮現為韓股槓桿 ETF 強制清算踩踏，週一美股重啟能否守穩是費半本週走向的關鍵觀察點。</span></div><div style=\"display:flex;gap:8px;align-items:baseline;padding:5px 0;border-bottom:1px dashed #232a36\"><span style=\"flex:none;font-family:ui-monospace,monospace;font-size:10.5px;color:#6b7385\">07/04 週六</span><span style=\"font-size:11.5px;line-height:1.55;color:#9aa5b8\">SOX 12626 兩日累挫逾 11% 後遇美國國慶長假凍結，台股週五僅微漲 +0.08% 顯示亞洲未恐慌接刀；金價 4187（+1.49%）與 VIX 15.81（−2.11%）的背離是週一開盤前最需驗證的訊號。</span></div></div></div></div></div><div class=\"con-panels\"><div style=\"background:#12151c;border:1px solid #2a3140;border-radius:12px;padding:11px 12px\"><div style=\"display:flex;align-items:baseline;gap:6px;margin-bottom:9px\"><span style=\"font-size:12.5px;font-weight:700\">資金浮力場</span><span class=\"con-eb\">BUOYANCY</span><a href=\"/sector_strength_tw.html\" style=\"margin-left:auto;font-size:11px;color:#60a5fa;text-decoration:none\">全版 →</a></di